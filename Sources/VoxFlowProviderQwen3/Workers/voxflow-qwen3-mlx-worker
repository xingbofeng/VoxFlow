#!/usr/bin/env python3
"""Qwen3-ASR 1.7B MLX worker entrypoint for VoxFlow.

The Swift provider talks to this executable with line-delimited JSON on stdin/stdout.
It performs a dependency health probe, loads the MLX model on session start, and
transcribes cumulative audio so Swift can surface preview/final updates.
"""

from __future__ import annotations

import argparse
import base64
import json
import math
import struct
import sys
import tempfile
import time
import uuid
import wave
from dataclasses import dataclass, field
from typing import Any, Callable


def write_json(payload: dict[str, Any]) -> None:
    sys.stdout.write(json.dumps(payload, ensure_ascii=False, separators=(",", ":")) + "\n")
    sys.stdout.flush()


def mlx_dependency_error() -> str | None:
    try:
        from mlx_audio.stt.generate import generate_transcription  # noqa: F401
        from mlx_audio.stt.utils import load_model  # noqa: F401
    except ModuleNotFoundError as error:
        return f"{error.name} is not installed"
    except Exception as error:  # pragma: no cover - depends on host MLX installation
        return str(error)
    return None


def emit_health() -> int:
    reason = mlx_dependency_error()
    if reason is None:
        write_json({"type": "health", "status": "healthy"})
    else:
        write_json({"type": "health", "status": "unhealthy", "reason": reason})
    return 0


@dataclass
class SessionState:
    model_path: str
    language_hint: str | None
    model: Any
    audio_bytes: bytearray = field(default_factory=bytearray)
    sample_rate: int = 16_000
    last_partial_audio_seconds: float = 0.0
    last_partial_wall_time: float = 0.0


class Worker:
    def __init__(self) -> None:
        self.sessions: dict[str, SessionState] = {}
        self.dependency_error = mlx_dependency_error()
        self.load_model: Callable[[str], Any] | None = None
        self.generate_transcription: Callable[..., Any] | None = None
        if self.dependency_error is None:
            from mlx_audio.stt.generate import generate_transcription
            from mlx_audio.stt.utils import load_model

            self.load_model = load_model
            self.generate_transcription = generate_transcription

    def serve(self) -> int:
        for line in sys.stdin.buffer:
            if not line.strip():
                continue
            try:
                request = json.loads(line)
                response = self.handle(request)
            except Exception as error:
                response = {
                    "type": "error",
                    "code": "worker_error",
                    "message": str(error),
                }
            write_json(response)
        return 0

    def handle(self, request: dict[str, Any]) -> dict[str, Any]:
        request_type = request.get("type")
        if request_type == "start":
            return self.start(request)
        if request_type == "add_audio":
            return self.add_audio(request)
        if request_type == "finish":
            return self.finish(request)
        if request_type == "cancel":
            return self.cancel(request)
        return {
            "type": "error",
            "code": "invalid_request",
            "message": f"Unknown Qwen3 MLX worker request type: {request_type}",
        }

    def start(self, request: dict[str, Any]) -> dict[str, Any]:
        if self.dependency_error is not None:
            return {
                "type": "error",
                "code": "runtime_unsupported",
                "message": f"Qwen3-ASR 1.7B MLX worker dependency check failed: {self.dependency_error}",
            }
        assert self.load_model is not None
        model_path = str(request.get("modelPath") or "")
        try:
            model = self.load_model(model_path)
        except Exception as error:
            return {
                "type": "error",
                "code": "model_load_failed",
                "message": str(error),
            }
        session_id = str(uuid.uuid4())
        self.sessions[session_id] = SessionState(
            model_path=model_path,
            language_hint=request.get("languageHint"),
            model=model,
        )
        return {"type": "started", "sessionID": session_id}

    def add_audio(self, request: dict[str, Any]) -> dict[str, Any]:
        session = self.session_for(request)
        if session is None:
            return self.missing_session()
        audio = request.get("audio") or {}
        payload = audio.get("samplesBase64")
        if isinstance(payload, str):
            session.audio_bytes.extend(base64.b64decode(payload))
        sample_rate = audio.get("sampleRate")
        if isinstance(sample_rate, int) and sample_rate > 0:
            session.sample_rate = sample_rate
        transcript = ""
        if self.should_transcribe_partial(session):
            transcript = self.transcribe(session)
            session.last_partial_audio_seconds = audio_duration_seconds(session)
            session.last_partial_wall_time = time.monotonic()
        return {
            "type": "partial",
            "transcript": transcript,
            "isFinal": False,
        }

    def finish(self, request: dict[str, Any]) -> dict[str, Any]:
        session = self.session_for(request)
        if session is None:
            return self.missing_session()
        transcript = self.transcribe(session)
        self.sessions.pop(str(request.get("sessionID")), None)
        return {"type": "final", "transcript": transcript}

    def cancel(self, request: dict[str, Any]) -> dict[str, Any]:
        session_id = request.get("sessionID")
        if isinstance(session_id, str):
            self.sessions.pop(session_id, None)
        return {"type": "cancelled"}

    def session_for(self, request: dict[str, Any]) -> SessionState | None:
        session_id = request.get("sessionID")
        if not isinstance(session_id, str):
            return None
        return self.sessions.get(session_id)

    @staticmethod
    def missing_session() -> dict[str, str]:
        return {
            "type": "error",
            "code": "invalid_session",
            "message": "Qwen3 MLX worker session was not found.",
        }

    def transcribe(self, session: SessionState) -> str:
        assert self.generate_transcription is not None
        if is_silent(session.audio_bytes):
            return ""
        with tempfile.NamedTemporaryFile(suffix=".wav", delete=True) as audio_file, \
                tempfile.NamedTemporaryFile(suffix=".txt", delete=True) as output_file:
            write_wav(audio_file.name, session.audio_bytes, session.sample_rate)
            result = self.generate_transcription(
                session.model,
                audio_file.name,
                output_path=output_file.name,
                format="txt",
                verbose=False,
                language=session.language_hint,
            )
        if isinstance(result, str):
            return result.strip()
        if isinstance(result, dict):
            return str(result.get("text", "")).strip()
        return str(getattr(result, "text", "")).strip()

    def should_transcribe_partial(self, session: SessionState) -> bool:
        if is_silent(session.audio_bytes):
            return False
        duration = audio_duration_seconds(session)
        if duration < 1.5:
            return False
        if duration - session.last_partial_audio_seconds < 1.5:
            return False
        if time.monotonic() - session.last_partial_wall_time < 2.0:
            return False
        return True


def is_silent(float32_little_endian: bytes | bytearray, rms_threshold: float = 0.0005) -> bool:
    squared_sum = 0.0
    sample_count = 0
    for offset in range(0, len(float32_little_endian), 4):
        chunk = float32_little_endian[offset: offset + 4]
        if len(chunk) < 4:
            break
        value = struct.unpack("<f", bytes(chunk))[0]
        squared_sum += value * value
        sample_count += 1
    if sample_count == 0:
        return True
    return math.sqrt(squared_sum / sample_count) < rms_threshold


def audio_duration_seconds(session: SessionState) -> float:
    bytes_per_float32_sample = 4
    if session.sample_rate <= 0:
        return 0.0
    return len(session.audio_bytes) / bytes_per_float32_sample / session.sample_rate


def write_wav(path: str, float32_little_endian: bytes | bytearray, sample_rate: int) -> None:
    samples = []
    for offset in range(0, len(float32_little_endian), 4):
        chunk = float32_little_endian[offset: offset + 4]
        if len(chunk) < 4:
            break
        value = max(-1.0, min(1.0, struct.unpack("<f", bytes(chunk))[0]))
        samples.append(int(value * 32767.0))
    pcm = struct.pack("<" + "h" * len(samples), *samples) if samples else b""
    with wave.open(path, "wb") as wav:
        wav.setnchannels(1)
        wav.setsampwidth(2)
        wav.setframerate(sample_rate)
        wav.writeframes(pcm)


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--health", action="store_true")
    args = parser.parse_args()
    if args.health:
        return emit_health()
    return Worker().serve()


if __name__ == "__main__":
    raise SystemExit(main())
