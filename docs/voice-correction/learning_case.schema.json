{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Voice Correction Learning Benchmark Case",
  "type": "object",
  "required": [
    "id",
    "rawText",
    "insertedText",
    "observedFinalText",
    "expectedCandidates",
    "expectedRevertedRuleIDs",
    "shouldLearn",
    "tags"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "rawText": {
      "type": "string"
    },
    "insertedText": {
      "type": "string"
    },
    "observedFinalText": {
      "type": "string"
    },
    "expectedCandidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "original",
          "replacement"
        ],
        "properties": {
          "original": {
            "type": "string"
          },
          "replacement": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "expectedRevertedRuleIDs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "shouldLearn": {
      "type": "boolean"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
